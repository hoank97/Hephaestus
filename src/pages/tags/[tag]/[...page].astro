---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import { slugifyAll, slugifyStr } from "@/utils/slugify";
import { SITE } from "@/config";

type ContentEntry = CollectionEntry<"blog"> | CollectionEntry<"questions">;

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");
  const questions = await getCollection("questions");

  // Get unique tags from both posts and questions
  const postTags = getUniqueTags(posts);
  const questionTagsSet = new Set<string>();

  questions.forEach(q => {
    q.data.tags.forEach(tag => {
      questionTagsSet.add(slugifyStr(tag));
    });
  });

  // Merge tags from both collections
  const allTagsMap = new Map(postTags.map(t => [t.tag, t.tagName]));
  questionTagsSet.forEach(tag => {
    if (!allTagsMap.has(tag)) {
      allTagsMap.set(tag, tag);
    }
  });

  const allTags = Array.from(allTagsMap.entries()).map(([tag, tagName]) => ({
    tag,
    tagName,
  }));

  return allTags.flatMap(({ tag, tagName }) => {
    const tagPosts = getPostsByTag(posts, tag);
    const tagQuestions = questions.filter(q =>
      slugifyAll(q.data.tags).includes(tag)
    );

    const allContent: ContentEntry[] = [...tagPosts, ...tagQuestions].sort(
      (a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf()
    );

    return paginate(allContent, {
      params: { tag },
      props: { tagName },
      pageSize: SITE.postPerPage,
    });
  });
}

const params = Astro.params;
const { tag } = params;
const { page, tagName } = Astro.props as { page: Page<ContentEntry>; tagName: string };
---

<Layout title={`Tag: ${tagName} | ${SITE.title}`}>
  <Header />
  <Main
    pageTitle={[`Tag:`, `${tagName}`]}
    titleTransition={tag}
    pageDesc={`All the articles with the tag "${tagName}".`}
  >
    <h1 slot="title" transition:name={tag}>{`Tag:${tag}`}</h1>
    <ul>
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
