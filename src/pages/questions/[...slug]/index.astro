---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { render } from "astro:content";

export async function getStaticPaths() {
  const questions = await getCollection("questions");
  return questions.map(question => ({
    params: { slug: question.id },
    props: { question },
  }));
}

const { question } = Astro.props;
const { Content } = await render(question);
---

<Layout
  title={question.data.question}
  description={question.data.answer.substring(0, 160)}
>
  <Header />
  <main id="main-content" class="app-layout py-8">
    <section class="border-b border-border pb-6">
      <a
        href="/questions"
        class="mb-4 inline-block text-sm text-accent hover:underline"
      >
        ← Back to Questions
      </a>
      <h1 class="text-3xl font-bold sm:text-4xl">{question.data.question}</h1>
      {
        question.data.tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {question.data.tags.map(tag => (
              <a
                href={`/tags/${tag}`}
                class="rounded-full bg-accent/10 px-3 py-1 text-xs text-accent hover:bg-accent/20 transition-colors"
              >
                {tag}
              </a>
            ))}
          </div>
        )
      }
    </section>

    <section class="pt-8 pb-6">
      <article class="app-prose max-w-none">
        <h2 class="text-xl font-semibold">Answer</h2>
        <p class="mt-4 leading-7">{question.data.answer}</p>
        <div class="mt-6">
          <Content />
        </div>
      </article>
    </section>
  </main>
  <Footer />
</Layout>
