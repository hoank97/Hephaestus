---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const questions = await getCollection("questions");

const sortedQuestions = questions.sort(
  (a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf()
);
---

<Layout title="Questions" description="Common questions and answers">
  <Header />
  <main id="main-content" class="app-layout py-8">
    <section class="border-b border-border pb-6">
      <h1 class="text-4xl font-bold sm:text-5xl">Questions</h1>
      <p class="mt-3 text-muted-foreground">
        A collection of common questions and their answers.
      </p>
    </section>

    <section class="pt-8 pb-6">
      {
        sortedQuestions.length > 0 ? (
          <ul class="space-y-3">
            {sortedQuestions.map(({ id, data }) => (
              <li>
                <a
                  href={`/questions/${id}`}
                  class="block rounded-lg border border-border p-4 transition-colors hover:border-accent hover:bg-accent/5"
                >
                  <h2 class="text-lg font-medium">{data.question}</h2>
                  {data.tags.length > 0 && (
                    <div class="mt-2 flex flex-wrap gap-2">
                      {data.tags.map(tag => (
                        <span class="rounded-full bg-accent/10 px-2 py-0.5 text-xs text-accent">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-muted-foreground">No questions available yet.</p>
        )
      }
    </section>
  </main>
  <Footer />
</Layout>
